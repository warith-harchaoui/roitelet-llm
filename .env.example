# Core application
ROITELET_ENV=development
ROITELET_DATA_DIR=./data
ROITELET_DEFAULT_TOP_K=2
ROITELET_CANDIDATE_POOL_SIZE=8
#
# === Network exposure — read this before changing the defaults ===
#
# start.sh defaults to 127.0.0.1 (localhost-only). The Docker image
# overrides ROITELET_APP_HOST to 0.0.0.0 inside the container because
# port-forwarding requires it; actual external exposure is then
# controlled by your `docker-compose.yml` port map / host firewall.
#
# Set ROITELET_APP_HOST=0.0.0.0 here ONLY if you want a bare-metal
# `./start.sh` run to bind every interface (LAN, VM port-forward,
# public IP, ngrok, Tailscale, …). In that case you MUST ALSO:
#   1. Set ROITELET_API_TOKEN to a non-empty value, AND
#   2. EITHER keep it behind a reverse proxy that handles auth,
#      OR accept that the token is your only line of defence.
#
# Without those two steps, anyone who can reach the port can read
# your conversations, your raw telemetry (including the prompts and
# provider responses), and trigger paid provider calls against your
# API keys.
ROITELET_APP_HOST=127.0.0.1
ROITELET_APP_PORT=8000
ROITELET_PUBLIC_BASE_URL=http://localhost:8000
# Comma-separated origins allowed by CORS. Default: same-origin only.
# Use "*" to allow any origin (downgrades to allow_credentials=False).
ROITELET_CORS_ALLOWED_ORIGINS=http://localhost:8000
# Bearer token. When non-empty, /api/chat, /api/settings,
# /api/conversations, /api/telemetry, /api/personal*, /api/images,
# and /v1/chat/completions all require Authorization: Bearer <token>.
# /healthz, /v1/models and the static SPA stay public so health
# probes work. LEAVE EMPTY ONLY FOR localhost-only single-user use.
ROITELET_API_TOKEN=
# TTL for cached paid-provider responses on disk (seconds).
# 0 disables caching (default). Negative means "cache forever".
ROITELET_PROVIDER_CACHE_TTL=0

# Router selection. Default is the heuristic blend documented in
# MECHANISM.md §3. Set to "mf" to engage the learned matrix-factorisation
# router (core/router_mf.py) — falls back to heuristic when fewer than
# 32 telemetry records exist.
ROITELET_ROUTER=heuristic

# Capability detector selection. Default is the keyword scan in
# core/capabilities.py. Set to "embedding" to use the sklearn classifier
# on top of local Ollama embeddings (requires the embedding model to be
# pulled — see ROITELET_EMBED_MODEL below). Falls back to keywords
# whenever the embedding call fails.
ROITELET_CAPABILITY_DETECTOR=keyword
ROITELET_EMBED_MODEL=nomic-embed-text

# Local synthesis / judge model (preferred)
#
# Two onboarding profiles (see docs/INSTALL.md):
#   - Minimal (~3 GB): scripts/pull_defaults.sh --minimal
#     → set LOCAL_LLM_MODEL=qwen3:4b
#   - Full local (~15 GB): scripts/pull_defaults.sh
#     → keep LOCAL_LLM_MODEL=qwen3:8b (default)
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=qwen3:8b
LOCAL_VLM_MODEL=qwen2.5vl:7b

# Paid routing via OpenRouter (recommended first setup)
OPENROUTER_API_KEY=sk-or-v1-fake...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Frontier Provider API Keys (if you prefer direct connections over OpenRouter)
OPENAI_API_KEY=sk-proj-fake...
ANTHROPIC_API_KEY=sk-ant-fake...
GEMINI_API_KEY=AIzaSyFake...
PERPLEXITY_API_KEY=pplx-fake...

# Optional direct OpenAI-compatible endpoint
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Hardware / monitoring defaults
ROITELET_POWER_USAGE_EFFECTIVENESS=1.35
ROITELET_GRID_CARBON_INTENSITY=475.0
ROITELET_MEMORY_POWER_WATTS_PER_GB=0.3725
ROITELET_DEFAULT_CPU_POWER_WATTS=65.0
ROITELET_DEFAULT_GPU_POWER_WATTS=220.0
