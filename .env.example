# Core application
ROITELET_ENV=development
ROITELET_DATA_DIR=./data
ROITELET_DEFAULT_TOP_K=3
ROITELET_CANDIDATE_POOL_SIZE=8
ROITELET_APP_HOST=0.0.0.0
ROITELET_APP_PORT=8000
ROITELET_PUBLIC_BASE_URL=http://localhost:8000
# Comma-separated origins allowed by CORS. Default: same-origin only.
# Use "*" to allow any origin (downgrades to allow_credentials=False).
ROITELET_CORS_ALLOWED_ORIGINS=http://localhost:8000
# Optional Bearer token. When non-empty, every chat, settings, conversation,
# and telemetry endpoint requires Authorization: Bearer <token>. /healthz,
# /v1/models, and the static SPA assets stay public. Leave empty for
# local-first single-user UX.
ROITELET_API_TOKEN=
# TTL for cached paid-provider responses on disk (seconds).
# 0 disables caching (default). Negative means "cache forever".
ROITELET_PROVIDER_CACHE_TTL=0

# Local synthesis / judge model (preferred)
# Defaults assume the Roitelet OSS bundle: pull with scripts/pull_defaults.sh
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_BASE_URL=http://localhost:11434
LOCAL_LLM_API_KEY=
LOCAL_LLM_MODEL=qwen3:8b
LOCAL_VLM_MODEL=qwen2.5vl:7b

# Paid routing via OpenRouter (recommended first setup)
OPENROUTER_API_KEY=sk-or-v1-fake...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Frontier Provider API Keys (if you prefer direct connections over OpenRouter)
OPENAI_API_KEY=sk-proj-fake...
ANTHROPIC_API_KEY=sk-ant-fake...
GEMINI_API_KEY=AIzaSyFake...
PERPLEXITY_API_KEY=pplx-fake...

# Optional direct OpenAI-compatible endpoint
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Hardware / monitoring defaults
ROITELET_POWER_USAGE_EFFECTIVENESS=1.35
ROITELET_GRID_CARBON_INTENSITY=475.0
ROITELET_MEMORY_POWER_WATTS_PER_GB=0.3725
ROITELET_DEFAULT_CPU_POWER_WATTS=65.0
ROITELET_DEFAULT_GPU_POWER_WATTS=220.0
